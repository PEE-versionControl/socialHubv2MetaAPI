# ──────────────────────────────────────────────────────────────
# Meta API Project — Environment Variables
# Copy this file to .env and fill in your own credentials.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# ── Default Account ────────────────────────────────────────────
# Display name shown in Social Hub for this account's posts.
ACCOUNT_NAME=Your Page Name

# Facebook Page Access Token (type: PAGE)
FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Numeric Facebook Page ID (e.g. 111982119268715)
FACEBOOK_PAGE_ID=000000000000000

# Ad Account ID — must include the "act_" prefix
FACEBOOK_AD_ACCOUNT_ID=act_000000000000000

# Instagram token (separate from FB Page token)
# Needs: instagram_basic, instagram_manage_insights, ads_read
IG_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Instagram Business Account ID (e.g. 17841404022248542)
IG_BUSINESS_ID=00000000000000000

# ── Additional Accounts (optional) ─────────────────────────────
# To add a second account, duplicate the block below with a
# unique PREFIX (all caps). The prefix becomes the account key.
#
# BRAND2_ACCOUNT_NAME=Second Brand
# BRAND2_FACEBOOK_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# BRAND2_FACEBOOK_PAGE_ID=000000000000001
# BRAND2_FACEBOOK_AD_ACCOUNT_ID=act_000000000000001
# BRAND2_IG_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
# BRAND2_IG_BUSINESS_ID=00000000000000001

# ── Firebase (Social Hub frontend) ─────────────────────────────
# Get these from your Firebase project's console →
# Project settings → Your apps → SDK setup and configuration
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxx
